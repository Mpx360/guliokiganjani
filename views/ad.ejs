<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gulio Mtandaoni — Premium Deals</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="ad-body">
  <header class="ad-header">
    <div class="ad-logo">Gulio Mtandaoni</div>
    <a href="/" class="ad-cta-top">Shop Now</a>
  </header>

  <section class="ad-hero">
    <div class="ad-hero-overlay"></div>
    <div class="ad-hero-content">
      <h1>Premium Marketplace.<br><span>Unbeatable Prices.</span></h1>
      <p>Discover exclusive deals on electronics, fashion, gaming, and lifestyle products. Delivered to your doorstep.</p>
      <div class="ad-hero-offers">
        <span>Up to 50% OFF</span>
        <span>Free Delivery</span>
        <span>Secure Payments</span>
      </div>
      <a href="/" class="ad-cta-hero">Enter Marketplace &rarr;</a>
    </div>
  </section>

  <section class="ad-features">
    <div class="ad-feature">
      <div class="ad-feature-icon">&#9733;</div>
      <h3>Premium Quality</h3>
      <p>Curated products from trusted sellers</p>
    </div>
    <div class="ad-feature">
      <div class="ad-feature-icon">&#128666;</div>
      <h3>Fast Delivery</h3>
      <p>Free shipping on orders over Tsh. 50,000/=</p>
    </div>
    <div class="ad-feature">
      <div class="ad-feature-icon">&#128274;</div>
      <h3>Secure Checkout</h3>
      <p>Your payments and data are always safe</p>
    </div>
    <div class="ad-feature">
      <div class="ad-feature-icon">&#128077;</div>
      <h3>24/7 Support</h3>
      <p>We're here to help anytime</p>
    </div>
  </section>

  <section class="ad-showcase">
    <h2 class="ad-section-title">Hot Deals This Week</h2>
    <div class="ad-products">
      <div class="ad-product-card">
        <span class="ad-offer-tag">-30%</span>
        <img src="/images/4k-ultra-hd-monitor-27.jpg" alt="Monitor">
        <h4>4K Ultra HD Monitor</h4>
        <p class="ad-old-price">Tsh. 350,000/=</p>
        <p class="ad-new-price">Tsh. 245,000/=</p>
      </div>
      <div class="ad-product-card">
        <span class="ad-offer-tag">-25%</span>
        <img src="/images/noise-cancelling-earbuds-pro.jpg" alt="Earbuds">
        <h4>Noise Cancelling Earbuds</h4>
        <p class="ad-old-price">Tsh. 120,000/=</p>
        <p class="ad-new-price">Tsh. 90,000/=</p>
      </div>
      <div class="ad-product-card">
        <span class="ad-offer-tag">-40%</span>
        <img src="/images/smartwatch-pro-max.jpg" alt="Smartwatch">
        <h4>Smartwatch Pro Max</h4>
        <p class="ad-old-price">Tsh. 200,000/=</p>
        <p class="ad-new-price">Tsh. 120,000/=</p>
      </div>
      <div class="ad-product-card">
        <span class="ad-offer-tag">-20%</span>
        <img src="/images/mechanical-gaming-keyboard-rgb.jpg" alt="Keyboard">
        <h4>RGB Gaming Keyboard</h4>
        <p class="ad-old-price">Tsh. 85,000/=</p>
        <p class="ad-new-price">Tsh. 68,000/=</p>
      </div>
    </div>
  </section>

  <section class="ad-banner">
    <div class="ad-banner-content">
      <h2>Join Thousands of Happy Shoppers</h2>
      <p>Sign up today and get 10% off your first order + free delivery!</p>
      <a href="/" class="ad-cta-banner">Create Account &amp; Save &rarr;</a>
    </div>
  </section>

  <footer class="ad-footer">
    <p>&copy; 2026 Gulio Mtandaoni — Premium Marketplace. All rights reserved.</p>
    <div class="ad-footer-links">
      <a href="/">Home</a>
      <a href="/marketplace">Marketplace</a>
    </div>
  </footer>
</body>
</html>
